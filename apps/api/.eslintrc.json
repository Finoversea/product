{
  "root": true,
  "parser": "@typescript-eslint/parser",
  "parserOptions": {
    "ecmaVersion": 2022,
    "sourceType": "module"
  },
  "extends": [
    "eslint:recommended"
  ],
  "env": {
    "node": true,
    "es2022": true
  },
  "rules": {
    "no-unused-vars": "warn"
  },
  "ignorePatterns": ["dist/", "node_modules/", "*.test.ts"]
}